{
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/static-build" },
    { "src": "backend/api/*.py",      "use": "@vercel/python" }
  ],
  "rewrites": [
    { "source": "/_/backend/(.*)", "destination": "backend/$1.py" },
    { "source": "/(.*)",           "destination": "frontend/$1" }
  ]
}
